# In dev, leave this blank — Vite proxies /api/* to localhost:3001 (see vite.config.js)
# In production (Vercel), set this to the public URL of your deployed backend.
# Examples:
#   VITE_API_URL=https://eventhub-backend.onrender.com
#   VITE_API_URL=https://eventhub-backend.up.railway.app
VITE_API_URL=
