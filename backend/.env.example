MONGO_URI=mongodb://localhost:27017/eventmgmt
PORT=3001
FRONTEND_URL=http://localhost:5173
JSP_BASE_URL=http://localhost:8080/event-mgmt

# From Razorpay test dashboard (https://dashboard.razorpay.com -> Settings -> API Keys, "Generate Test Key")
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me

# Optional: pin Ethereal credentials to keep the same inbox across restarts.
# Leave blank to auto-create a fresh test account on each boot.
ETHEREAL_USER=
ETHEREAL_PASS=
